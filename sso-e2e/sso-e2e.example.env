# Copy to `.env` (gitignored) and fill in. Every value is read at startup.
# A method whose required vars are unset is skipped automatically.

# --- Platform login (the Go Vocal user that gets verified) ---
# For a meaningful assertion, use an UNVERIFIED test user. Defaults to the
# seeded admin, which may already be verified.
PLATFORM_USER_EMAIL=admin@govocal.com
PLATFORM_USER_PASSWORD=democracy2.0

# --- fake_sso (local) ---
# No credentials. Optionally pick a seeded profile (e.g. jane_doe = no email).
# FAKE_SSO_PROFILE=

# --- Keycloak / ID-Porten (test realm) ---
KEYCLOAK_TEST_USER=
KEYCLOAK_TEST_PASSWORD=

# --- Auth0 ---
AUTH0_TEST_USER=
AUTH0_TEST_PASSWORD=

# --- FranceConnect (integration) ---
FRANCECONNECT_TEST_USER=
FRANCECONNECT_TEST_PASSWORD=
# Test identity-provider tile to click on the FranceConnect hub (default: FIP1).
# FRANCECONNECT_PROVIDER_LABEL=FIP1

# --- Clave Única (test) ---
CLAVE_UNICA_TEST_USER=
CLAVE_UNICA_TEST_PASSWORD=
