  .card-header-date { font-size: 8px; color: rgba(255, 255, 255, 0.75); }
  .card-body { padding: 10px 12px; }
  .qa { margin-bottom: 8px; }
  .qa:last-child { margin-bottom: 0; }
  .qa-question {
    background: #F0EEFA;
    color: #43369B;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 3px;
  }
  .qa-answer {
    border: 1px solid #E1DEF5;
    border-radius: 3px;
    padding: 6px 8px;
    margin-top: 3px;
    font-size: 11px;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .qa-answer.empty { color: #968BDD; }
  .footer {
    text-align: center;
    font-size: 8px;
    color: #968BDD;
    margin-top: 8px;
