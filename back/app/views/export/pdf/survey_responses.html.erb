<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <style>@page { size: A4; margin: 16mm; }</style>
    <%= render 'export/pdf/styles' %>
  </head>
  <body>
    <% if cover[:include] %>
      <%= render 'export/pdf/cover', cover: cover, total: total %>
    <% end %>

    <% respondents.each do |respondent| %>
      <div class="card">
        <div class="card-header">
          <span class="card-header-label"><%= t('pdf_export.survey_responses.respondent', number: format('%03d', respondent[:number])) %></span>
          <span class="card-header-date"><%= respondent[:date] %></span>
        </div>
        <div class="card-body">
          <% respondent[:answers].each do |answer| %>
            <div class="qa">
              <div class="qa-question"><%= answer[:question] %></div>
              <% if answer[:answer].present? %>
                <div class="qa-answer"><%= answer[:answer] %></div>
              <% else %>
                <div class="qa-answer empty"><%= t('pdf_export.survey_responses.no_answer') %></div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="footer"><%= t('pdf_export.survey_responses.response_count', count: total) %></div>
  </body>
</html>
