<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <%# Standalone A4 page for the in-UI cover preview. Replicates the PDF's
        16mm page margin with body padding (since @page margins don't apply on
        screen), then renders the shared cover partial. %>
    <style>
      html { background: #FFFFFF; }
      body {
        width: 210mm;
        height: 297mm;
        padding: 16mm;
        background: #FFFFFF;
      }
    </style>
    <%= render 'export/pdf/styles', colors: colors %>
  </head>
  <body>
    <%= render 'export/pdf/cover', cover: cover, total: total %>
  </body>
</html>
