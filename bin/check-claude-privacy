#!/usr/bin/env bash
# bin/check-claude-privacy — privacy guard for the citizenlab-claude overlay.
#
# Runs in CI (and can be run locally). Exits non-zero if anything looks like a leak.
# Pre-commit hook at .githooks/pre-commit catches the same cases on commit.

set -euo pipefail

errors=0

# 1. No tracked files under the private overlay paths.
LEAKED="$(git ls-files .claude/private .claude/skills .claude/README.md 2>/dev/null || true)"
if [ -n "$LEAKED" ]; then
  echo "ERROR: tracked files under private overlay paths:" >&2
  echo "$LEAKED" | sed 's/^/  /' >&2
  errors=$((errors + 1))
fi

# 2. Every public CLAUDE.md must reference a private overlay via @import,
#    so that accidental stripping of the import line is caught.
while IFS= read -r f; do
  [ -z "$f" ] && continue
  if ! grep -qE '^@\.{0,2}/?\.claude/private/' "$f"; then
    echo "ERROR: $f is missing the expected '@.../.claude/private/...' import line." >&2
    errors=$((errors + 1))
  fi
done < <(git ls-files '*/CLAUDE.md' 'CLAUDE.md')

if [ "$errors" -gt 0 ]; then
  echo "" >&2
  echo "Privacy check failed with $errors error(s)." >&2
  exit 1
fi

echo "Claude privacy check passed."
